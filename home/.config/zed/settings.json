{
  "proxy": "",
  "tab_bar": {
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": false
  },
  "tabs": {
    "file_icons": false,
    "git_status": true
  },
  "show_whitespaces": "all",
  "minimap": {
    "thumb": "always",
    "show": "auto"
  },
  "diff_view_style": "split",
  "project_panel": {
    "git_status_indicator": true,
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left"
  },
  "git_panel": {
    "show_count_badge": false,
    "file_icons": false,
    "status_style": "icon",
    "button": true,
    "tree_view": true,
    "dock": "left"
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha"
  },
  "edit_predictions": {
    "provider": "zed"
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "vim_mode": false,
  "tab_size": 2,
  "unnecessary_code_fade": 0.7,
  "indent_guides": {
    "background_coloring": "disabled",
    "enabled": true,
    "coloring": "indent_aware"
  },
  "agent": {
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4"
    }
  },
  "ui_font_size": 14.0,
  "ui_font_weight": 600.0,
  "buffer_font_size": 13.0,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": "JetBrainsMono Nerd Font",
  "relative_line_numbers": "enabled",
  "theme": {
    "mode": "dark",
    "light": "Tokyo Night Light",
    "dark": "Tokyo Night"
  },
  "buffer_font_features": {
    "liga": false,
    "calt": false
  },
  "lsp": {
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path=stdout",
          "--issues-exit-code=1",
          "--show-stats=false"
        ]
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": [
          "class",
          "className",
          "cva",
          "cn"
        ]
      }
    },
    "biome": {
      "settings": {
        "require_config_file": true
      }
    }
  },
  "formatter": "language_server",
  "languages": {
    "Go": {
      "show_edit_predictions": false,
      "language_servers": [
        "gopls",
        "golangci-lint"
      ]
    },
    "JavaScript": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TypeScript": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TSX": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "CSS": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    }
  },
  "terminal": {
    "working_directory": "current_project_directory"
  },
  "auto_install_extensions": {
    "basher": true,
    "biome": true,
    "catppuccin-icons": true,
    "csv": true,
    "docker-compose": true,
    "dockerfile": true,
    "env": true,
    "git-firefly": true,
    "html": true,
    "log": true,
    "lua": true,
    "proto": true,
    "pylsp": true,
    "sql": true,
    "tmux": true,
    "tokyo-night": true,
    "toml": true,
    "typos": true
  }
}
